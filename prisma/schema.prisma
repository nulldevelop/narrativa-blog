generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum ROLES {
  OWNER
  ADMIN
  EDITOR
  AUTHOR
}

enum STATUSPUBLISH {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum STATUS {
  ACTIVE
  INACTIVE
}

enum LogAction {
  CREATE
  UPDATE
  DELETE
}

// ─── AUTH (Better Auth) ─────────────────────────────────

model User {
  id              String       @id @default(uuid())
  name            String       @db.Text
  email           String
  emailVerified   Boolean      @default(false)
  image           String?      @db.Text
  role            ROLES        @default(AUTHOR)
  bio             String?      @db.Text
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  sessions        Session[]
  accounts        Account[]
  articles        Article[]
  username        String?
  displayUsername String?      @db.Text
  members         Member[]
  invitations     Invitation[]

  @@unique([email])
  @@unique([username])
  @@map("user")
}

model Session {
  id        String   @id @default(uuid())
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?  @db.Text
  userAgent String?  @db.Text
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  activeOrganizationId String? @db.Text

  @@unique([token])
  @@index([userId(length: 191)])
  @@map("session")
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String    @db.Text
  providerId            String    @db.Text
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?   @db.Text
  password              String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId(length: 191)])
  @@map("account")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String   @db.Text
  value      String   @db.Text
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier(length: 191)])
  @@map("verification")
}

// ─── BLOG ───────────────────────────────────────────────

model Article {
  id          String       @id @default(uuid())
  title       String       @db.VarChar(300)
  slug        String       @unique @db.VarChar(300)
  subtitle    String?      @db.Text
  content     String       @db.LongText
  excerpt     String?      @db.Text
  coverImage  String?      @db.Text
  readTime    Int?
  featured    Boolean      @default(false)
  status      String       @default("draft") @db.VarChar(20)
  publishedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  authorId    String
  author      User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  categoryId  String?
  category    Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags        ArticleTag[]

  @@index([authorId])
  @@index([categoryId])
  @@index([status, publishedAt])
  @@map("article")
}

model Category {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  description String?  @db.Text
  color       String?  @db.VarChar(7)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  articles Article[]

  @@map("category")
}

model Tag {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  slug      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now())

  articles ArticleTag[]

  @@map("tag")
}

model ArticleTag {
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@index([tagId(length: 191)])
  @@map("article_tag")
}

// ─── NEWSLETTER ─────────────────────────────────────────

model Subscriber {
  id             String    @id @default(uuid())
  email          String    @unique @db.VarChar(255)
  confirmed      Boolean   @default(false)
  confirmToken   String?   @unique @db.VarChar(255)
  unsubscribedAt DateTime?
  createdAt      DateTime  @default(now())

  @@map("subscriber")
}

// ─── SITE ───────────────────────────────────────────────

model SiteConfig {
  id    String @id @default(uuid())
  key   String @unique @db.VarChar(100)
  value String @db.LongText

  @@map("site_config")
}

model Page {
  id        String   @id @default(uuid())
  title     String   @db.VarChar(300)
  slug      String   @unique @db.VarChar(300)
  content   String   @db.LongText
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("page")
}

model Organization {
  id                String             @id @default(uuid())
  name              String             @db.Text
  slug              String
  logo              String?            @db.Text
  email             String             @default("")
  telefone          String?
  cnpj              String?
  status            String             @default("ACTIVE")
  createdAt         DateTime           @default(now())
  metadata          String?            @db.Text
  members           Member[]
  invitations       Invitation[]
  auditLogs         AuditLog[]
  modulos           Modulo[]
  memberPermissions MemberPermission[]
  lotacoes          Lotacao[]
  apiSyncLogs       ApiSyncLog[]

  // API Integration Config
  apiUrlContratos  String? @db.Text
  apiUrlLicitacoes String? @db.Text
  apiUrlFiscais    String? @db.Text
  apiUrlAditivos   String? @db.Text
  autoLinkFiscais  Boolean @default(false)

  // SMTP Config
  smtpHost    String? @db.Text
  smtpPort    Int?
  smtpUser    String? @db.Text
  smtpPass    String? @db.Text
  smtpFrom    String? @db.Text
  notifyEmail String? @db.Text

  // Sync Status
  lastSyncAt      DateTime?
  lastSyncStatus  String?   @db.Text
  lastSyncMessage String?   @db.Text

  @@unique([slug])
  @@map("organization")
}

model ApiSyncLog {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  status         String       @db.Text // SUCCESS, ERROR, WARNING
  message        String       @db.Text
  details        String?      @db.LongText
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
  @@map("api_sync_log")
}

model Member {
  id             String             @id @default(uuid())
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           ROLES              @default(AUTHOR)
  fiscalCpf      String?
  lotacaoId      String?
  lotacao        Lotacao?           @relation(fields: [lotacaoId], references: [id], onDelete: SetNull)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  permissions    MemberPermission[]

  @@unique([userId, organizationId])
  @@index([organizationId(length: 191)])
  @@index([userId(length: 191)])
  @@map("member")
}

model Modulo {
  id             String             @id @default(uuid())
  key            String
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  permissions    MemberPermission[]

  @@unique([organizationId, key])
  @@map("modulo")
}

model MemberPermission {
  id             String       @id @default(uuid())
  memberId       String
  member         Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  moduloId       String
  modulo         Modulo       @relation(fields: [moduloId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  canCreate      Boolean      @default(false)
  canRead        Boolean      @default(true)
  canUpdate      Boolean      @default(false)
  canDelete      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([memberId, moduloId])
  @@map("member_permission")
}

model Invitation {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String       @db.Text
  role           String?      @db.Text
  status         String       @db.Text
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId(length: 191)])
  @@index([email(length: 191)])
  @@map("invitation")
}

model AuditLog {
  id             String       @id @default(uuid())
  action         LogAction
  entity         String       @db.Text
  entityId       String?      @db.Text
  entityName     String?      @db.Text
  userId         String       @db.Text
  userName       String       @db.Text
  userEmail      String       @db.Text
  organizationId String
  description    String?      @db.Text
  before         String?      @db.LongText
  after          String?      @db.LongText
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@map("audit_log")
}
