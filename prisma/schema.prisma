generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id              String       @id @default(uuid())
  name            String       @db.Text
  email           String       @unique
  emailVerified   Boolean      @default(false)
  image           String?      @db.Text
  role            ROLES        @default(AUTHOR)
  bio             String?      @db.Text
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  username        String?      @unique
  displayUsername String?      @db.Text
  accounts        Account[]
  articles        Article[]
  invitations     Invitation[]
  members         Member[]
  sessions        Session[]

  @@map("user")
}

model Session {
  id                   String   @id @default(uuid())
  expiresAt            DateTime
  token                String   @unique
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  ipAddress            String?  @db.Text
  userAgent            String?  @db.Text
  userId               String
  activeOrganizationId String?  @db.Text
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "session_userId_fkey")
  @@map("session")
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String    @db.Text
  providerId            String    @db.Text
  userId                String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?   @db.Text
  password              String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "account_userId_fkey")
  @@map("account")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String   @db.Text
  value      String   @db.Text
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

model Article {
  id             String        @id @default(uuid())
  title          String        @db.VarChar(300)
  slug           String        @unique @db.VarChar(300)
  subtitle       String?       @db.Text
  content        String        @db.LongText
  excerpt        String?       @db.Text
  coverImage     String?       @db.Text
  coverImageCredit String?      @db.Text
  readTime       Int?
  featured       Boolean       @default(false)
  status         String        @default("draft") @db.VarChar(20)
  publishedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  authorId       String
  categoryId     String?
  organizationId String?
  author         User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category       Category?     @relation(fields: [categoryId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tags           ArticleTag[]

  @@index([authorId], map: "article_authorId_fkey")
  @@index([categoryId], map: "article_categoryId_fkey")
  @@index([organizationId], map: "article_organizationId_fkey")
  @@map("article")
}

model Category {
  id             String        @id @default(uuid())
  name           String        @db.VarChar(100)
  slug           String        @unique @db.VarChar(100)
  description    String?       @db.Text
  color          String?       @db.VarChar(7)
  sortOrder      Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organizationId String?
  articles       Article[]
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId], map: "category_organizationId_fkey")
  @@map("category")
}

model Tag {
  id             String        @id @default(uuid())
  name           String        @db.VarChar(100)
  slug           String        @unique @db.VarChar(100)
  createdAt      DateTime      @default(now())
  organizationId String?
  articles       ArticleTag[]
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId], map: "tag_organizationId_fkey")
  @@map("tag")
}

model ArticleTag {
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@index([tagId], map: "article_tag_tagId_fkey")
  @@map("article_tag")
}

model Subscriber {
  id             String        @id @default(uuid())
  email          String        @db.VarChar(255)
  confirmed      Boolean       @default(false)
  confirmToken   String?       @unique @db.VarChar(255)
  unsubscribedAt DateTime?
  createdAt      DateTime      @default(now())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([email, organizationId])
  @@index([organizationId], map: "subscriber_organizationId_fkey")
  @@map("subscriber")
}

model SiteConfig {
  id             String        @id @default(uuid())
  key            String        @db.VarChar(100)
  value          String        @db.LongText
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([key, organizationId])
  @@index([organizationId], map: "site_config_organizationId_fkey")
  @@map("site_config")
}

model Page {
  id             String        @id @default(uuid())
  title          String        @db.VarChar(300)
  slug           String        @unique @db.VarChar(300)
  content        String        @db.LongText
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId], map: "page_organizationId_fkey")
  @@map("page")
}

model Curta {
  id             String        @id @default(uuid())
  texto          String        @db.Text
  source         String?       @db.Text
  status         String        @default("active") @db.VarChar(20)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("curta")
}

model Organization {
  id                String             @id @default(uuid())
  name              String             @db.Text
  slug              String             @unique
  logo              String?            @db.Text
  email             String             @default("")
  telefone          String?
  cnpj              String?
  status            String             @default("ACTIVE")
  createdAt         DateTime           @default(now())
  metadata          String?            @db.Text
  articles          Article[]
  auditLogs         AuditLog[]
  categories        Category[]
  invitations       Invitation[]
  members           Member[]
  memberPermissions MemberPermission[]
  modulos           Modulo[]
  pages             Page[]
  siteConfigs       SiteConfig[]
  subscribers       Subscriber[]
  tags              Tag[]

  @@map("organization")
}

model Member {
  id             String             @id @default(uuid())
  organizationId String
  userId         String
  role           ROLES              @default(AUTHOR)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  lotacaoId      String?
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissions    MemberPermission[]

  @@unique([userId, organizationId])
  @@index([organizationId], map: "member_organizationId_fkey")
  @@map("member")
}

model Modulo {
  id             String             @id @default(uuid())
  key            String
  organizationId String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  permissions    MemberPermission[]
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@map("modulo")
}

model MemberPermission {
  id             String       @id @default(uuid())
  memberId       String
  moduloId       String
  organizationId String
  canCreate      Boolean      @default(false)
  canRead        Boolean      @default(true)
  canUpdate      Boolean      @default(false)
  canDelete      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  member         Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  modulo         Modulo       @relation(fields: [moduloId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([memberId, moduloId])
  @@index([moduloId], map: "member_permission_moduloId_fkey")
  @@index([organizationId], map: "member_permission_organizationId_fkey")
  @@map("member_permission")
}

model Invitation {
  id             String       @id @default(uuid())
  organizationId String
  email          String       @db.Text
  role           String?      @db.Text
  status         String       @db.Text
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([inviterId], map: "invitation_inviterId_fkey")
  @@index([organizationId], map: "invitation_organizationId_fkey")
  @@map("invitation")
}

model AuditLog {
  id             String       @id @default(uuid())
  action         LogAction
  entity         String       @db.Text
  entityId       String?      @db.Text
  entityName     String?      @db.Text
  userId         String       @db.Text
  userName       String       @db.Text
  userEmail      String       @db.Text
  organizationId String
  description    String?      @db.Text
  before         String?      @db.LongText
  after          String?      @db.LongText
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId], map: "audit_log_organizationId_fkey")
  @@map("audit_log")
}

enum ROLES {
  OWNER
  ADMIN
  EDITOR
  AUTHOR
}

enum LogAction {
  CREATE
  UPDATE
  DELETE
}
